{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "menuQr": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/menu-qr",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css",
              "src/assets/coffee/css/linearicons.css",
              "src/assets/coffee/css/font-awesome.min.css",
              "src/assets/coffee/css/bootstrap.css",
              "src/assets/coffee/css/magnific-popup.css",
              "src/assets/coffee/css/nice-select.css",
              "src/assets/coffee/css/animate.min.css",
              "src/assets/coffee/css/owl.carousel.css",
              "src/assets/coffee/css/main.css",
              "src/assets/restaurant/assets/vendor/bootstrap/css/bootstrap.min.css",
              "src/assets/restaurant/assets/vendor/bootstrap-icons/bootstrap-icons.css",
              "src/assets/restaurant/assets/vendor/aos/aos.css",
              "src/assets/restaurant/assets/vendor/glightbox/css/glightbox.min.css",
              "src/assets/restaurant/assets/vendor/swiper/swiper-bundle.min.css",
              "src/assets/restaurant/assets/css/main.css",
              "src/assets/pato/vendor/bootstrap/css/bootstrap.min.css",
              "src/assets/pato/fonts/font-awesome-4.7.0/css/font-awesome.min.css",
              "src/assets/pato/fonts/themify/themify-icons.css",
              "src/assets/pato/vendor/animate/animate.css",
              "src/assets/pato/vendor/css-hamburgers/hamburgers.min.css",
              "src/assets/pato/vendor/animsition/css/animsition.min.css",
              "src/assets/pato/vendor/select2/select2.min.css",
              "src/assets/pato/vendor/daterangepicker/daterangepicker.css",
              "src/assets/pato/vendor/slick/slick.css",
              "src/assets/pato/vendor/lightbox2/css/lightbox.min.css",
              "src/assets/pato/css/util.css",
              "src/assets/pato/css/main.css",
              "src/assets/tasty/css/animate.css",
              "src/assets/tasty/css/icomoon.css",
              "src/assets/tasty/css/bootstrap.css",
              "src/assets/tasty/css/flexslider.css",
              "src/assets/tasty/css/style.css"
            ],
            "scripts": [
              "src/assets/coffee/js/vendor/jquery-2.2.4.min.js",
              "src/assets/coffee/js/vendor/bootstrap.min.js",
              "src/assets/coffee/js/easing.min.js",
              "src/assets/coffee/js/hoverIntent.js",
              "src/assets/coffee/js/superfish.min.js",
              "src/assets/coffee/js/jquery.ajaxchimp.min.js",
              "src/assets/coffee/js/jquery.magnific-popup.min.js",
              "src/assets/coffee/js/owl.carousel.min.js",
              "src/assets/coffee/js/jquery.sticky.js",
              "src/assets/coffee/js/jquery.nice-select.min.js",
              "src/assets/coffee/js/parallax.min.js",
              "src/assets/coffee/js/waypoints.min.js",
              "src/assets/coffee/js/jquery.counterup.min.js",
              "src/assets/coffee/js/mail-script.js",
              "src/assets/coffee/js/main.js",
              "src/assets/pato/vendor/jquery/jquery-3.2.1.min.js",
              "src/assets/pato/vendor/bootstrap/js/bootstrap.min.js",
              "src/assets/pato/vendor/animsition/js/animsition.min.js",
              "src/assets/pato/vendor/select2/select2.min.js",
              "src/assets/pato/vendor/daterangepicker/moment.min.js",
              "src/assets/pato/vendor/daterangepicker/daterangepicker.js",
              "src/assets/pato/vendor/slick/slick.min.js",
              "src/assets/pato/vendor/parallax100/parallax100.js",
              "src/assets/pato/vendor/lightbox2/js/lightbox.min.js",
              "src/assets/pato/vendor/isotope/isotope.pkgd.min.js",
              "src/assets/pato/js/main.js",
              "src/assets/restaurant/assets/vendor/bootstrap/js/bootstrap.bundle.min.js",
              "src/assets/restaurant/assets/vendor/php-email-form/validate.js",
              "src/assets/restaurant/assets/vendor/aos/aos.js",
              "src/assets/restaurant/assets/vendor/glightbox/js/glightbox.min.js",
              "src/assets/restaurant/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js",
              "src/assets/restaurant/assets/vendor/isotope-layout/isotope.pkgd.min.js",
              "src/assets/restaurant/assets/vendor/swiper/swiper-bundle.min.js",
              "src/assets/restaurant/assets/js/main.js",
              "src/assets/tasty/js/modernizr-2.6.2.min.js",
              "src/assets/tasty/js/jquery.min.js",
              "src/assets/tasty/js/jquery.easing.1.3.js",
              "src/assets/tasty/js/bootstrap.min.js",
              "src/assets/tasty/js/jquery.waypoints.min.js",
              "src/assets/tasty/js/jquery.stellar.min.js",
              "src/assets/tasty/js/jquery.flexslider-min.js",
              "src/assets/tasty/js/main.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kb",
                  "maximumError": "40kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "menuQr:build:production"
            },
            "development": {
              "buildTarget": "menuQr:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "menuQr:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}